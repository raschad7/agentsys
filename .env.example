OPENAI_API_KEY=

# Lead source(s):
#   "osm"     → OpenStreetMap only (free, real, no key)
#   "tavily"  → Tavily web search + GPT extraction (broad, free 1k/mo)
#   "apify"   → Apify Instagram + Facebook scraping (paid)
#   "social"  → tavily + apify combined — best for social-first regions
#               (West Bank, Gaza, MENA — anywhere Google Maps is thin)
#   "openai"  → AI-generated demo leads (fake, do not contact)
#   "auto"    → osm → tavily → apify → openai (default)
LEAD_FINDER_SOURCE=auto

# Tavily (https://tavily.com/) — free 1000 searches/month
TAVILY_API_KEY=

# Apify (https://apify.com/) — $5 free monthly credit
# Account → Settings → Integrations → API tokens
APIFY_TOKEN=
# Hard cap on Apify results per search (cost guardrail)
APIFY_MAX_RESULTS=20

INSTANTLY_API_KEY=
INSTANTLY_CAMPAIGN_ID=
INSTANTLY_API_VERSION=auto
SUPABASE_URL=
SUPABASE_KEY=

# B10 — ZeroBounce email verification (https://www.zerobounce.net/)
# Free tier: 100 verifications. Paid: ~$0.008/verify.
# Postie validates every recipient (after MX gate, before send) and refuses
# to send to spamtraps / invalid / abuse addresses. Cached 7 days.
ZEROBOUNCE_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Tier-A1 production guardrails ─────────────────────────────────────── #

# Shared secret guarding the /api/* endpoints. Generated automatically on
# first start (and printed once to stdout) if you don't set it here. Set it
# explicitly to keep the key stable across restarts.
AGENTFLOW_API_KEY=

# Hard daily spend cap on OpenAI calls (USD). 0 or unset = no cap. The
# tracker is in-memory per-process; restart resets it. Multi-worker setups
# should swap to Redis (Tier-C work).
OPENAI_DAILY_USD_CAP=5

# Domain dedupe TTL (days): leads whose email/website domain we've already
# seen in this window are skipped before enrichment. Hardcoded for now in
# graph/search_pipeline.py — tune there if you need different.
